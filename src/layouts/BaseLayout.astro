---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Groundspeed Labs — practical tools, no nonsense.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="logo">Groundspeed Labs</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      &copy; {new Date().getFullYear()} Groundspeed Labs
    </footer>
  </body>
</html>
