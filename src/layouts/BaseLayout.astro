---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  contentMode?: 'standard' | 'wide';
}

const {
  title,
  description = 'Groundspeed Labs — practical tools, no nonsense.',
  contentMode = 'standard',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="logo">Groundspeed Labs</a>
        <div class="nav-actions">
          <a href="/keepvalid/" class="nav-link">KeepValid</a>
          <a href="/keepvalid/#updates" class="header-cta">Get Updates</a>
        </div>
      </nav>
    </header>

    <main>
      <div class:list={['page-shell', contentMode === 'wide' && 'page-shell-wide']}>
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      &copy; {new Date().getFullYear()} Groundspeed Labs
    </footer>
  </body>
</html>
