---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Groundspeed Labs">
  <h1>Groundspeed Labs</h1>
  <p class="tagline">Practical tools. No nonsense.</p>

  <a href="/keepvalid/" class="app-card">
    <h2>KeepValid <span class="arrow">&rarr;</span></h2>
    <p>
      Track your document expiration dates. Get reminded before your ID,
      passport, license, or any other document expires. Scan it, forget it,
      get notified.
    </p>
  </a>
</BaseLayout>
