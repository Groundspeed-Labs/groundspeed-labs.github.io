---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="KeepValid — Never let a document expire"
  description="KeepValid tracks your document expiration dates and reminds you before they expire. Scan, forget, get notified."
>
  <h1>KeepValid</h1>
  <p class="tagline">Never let a document expire.</p>

  <p>
    KeepValid watches your documents so you don't have to. Point your camera at
    an ID, passport, driver's license, or credit card — it reads the expiry date
    automatically and reminds you before it's too late.
  </p>

  <ul class="features">
    <li>Scan documents with your camera — expiry dates detected automatically</li>
    <li>Get notified by push or email, days or months in advance</li>
    <li>All processing happens on your device — your documents never leave your phone</li>
    <li>Works with IDs, passports, licenses, cards, and more</li>
  </ul>

  <!-- TODO: Replace with actual Play Store URL once published -->
  <span class="cta" style="opacity: 0.6; cursor: default;">Coming soon on Google Play</span>

  <p style="margin-top: 2rem; font-size: 0.9rem; color: var(--color-text-muted);">
    <a href="/keepvalid/privacy/">Privacy Policy</a>
  </p>
</BaseLayout>
